{
    "name": "hiblaphp/schema-manager",
    "description": "Schema, Migration, and Seeding Management for the Hibla Database Ecosystem",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Reymart A. Calicdan",
            "email": "reymart.calicdan06@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Hibla\\SchemaManager\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.4",
        "hiblaphp/query-builder": "dev-main",
        "symfony/console": "^7.3",
        "doctrine/inflector": "^2.1",
        "nesbot/carbon": "^3.10"
    },
    "require-dev": {
        "laravel/pint": "^1.10",
        "pestphp/pest": "^3.0",
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0"
    },
    "bin": [
        "bin/hibla-db"
    ],
    "scripts": {
        "test": "./vendor/bin/pest",
        "format": "./vendor/bin/pint",
        "format-test": "./vendor/bin/pint --test",
        "analyze": "./vendor/bin/phpstan analyse"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}